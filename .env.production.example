# Copy this file to .env on your VPS and fill in the values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Postgres password — choose a strong random string (e.g. `openssl rand -hex 32`)
POSTGRES_PASSWORD=change_me_use_a_strong_password

# ── App ───────────────────────────────────────────────────────────────────────
# Set to "true" to run in landing-page-only mode (no Clerk required).
# Clerk keys can be left empty when LANDING_ONLY=true.
LANDING_ONLY=false

# ── Clerk Authentication ──────────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# ── File Uploads (optional) ───────────────────────────────────────────────────
# https://uploadthing.com/dashboard → API Keys
UPLOADTHING_TOKEN=

# ── SSL / Domain (for certbot) ────────────────────────────────────────────────
DOMAIN=your-domain.com
CERTBOT_EMAIL=you@example.com
